  renderCalendar();
  renderDayView(activeDayId);
  renderStandings();
  renderHistory();
}

// ── SEED DAY 1 PICKS ──
async function seedDay1Picks() {
  for (const pick of DAY1_PICKS) {
    // Check if pick exists
    const { data } = await sb.from('picks').select('id').eq('day_date', pick.day_date).eq('player_id', pick.player_id).maybeSingle();
    if (!data) {
      // Need user_id — look up by checking profiles or just insert with a placeholder
      // We'll insert after users sign up by checking their profile
      // For now just note it — we'll insert when the specific user logs in
    }
  }

  // Insert this user's day 1 pick if they have one
  const email = currentUser.email.toLowerCase();
  const myDay1 = DAY1_PICKS.find(p => p.email === email);
  if (myDay1) {
    const { data: existing } = await sb.from('picks').select('id').eq('user_id', currentUser.id).eq('day_date', myDay1.day_date).maybeSingle();
    if (!existing) {
      await sb.from('picks').insert({
        user_id: currentUser.id,
        day_date: myDay1.day_date,
        player_id: myDay1.player_id,
        player_name: myDay1.player_name,
        team: myDay1.team,
        locked: true,
        pts: myDay1.pts,
        reb: myDay1.reb,
        ast: myDay1.ast,
      });
    }
  }

  // Also insert profile if not exists
  const { data: prof } = await sb.from('profiles').select('id').eq('id', currentUser.id).maybeSingle();
  if (!prof) {
    await sb.from('profiles').insert({ id: currentUser.id, name: currentProfile.name });
  }
}

// ── LOAD ALL PICKS ──
async function loadAllPicks() {
  const { data, error } = await sb.from('picks').select('*');
  if (error) { console.error(error); return; }
  allPicks = {};
  if (data) {
    data.forEach(pick => {
      if (!allPicks[pick.user_id]) allPicks[pick.user_id] = {};
      allPicks[pick.user_id][pick.day_date] = pick;
    });
  }
}

// ── MARK USED PLAYERS ──
function markUsedPlayers() {
  const myPickedIds = new Set();
  const myUserPicks = allPicks[currentUser.id] || {};
  Object.values(myUserPicks).forEach(pick => {
    if (pick.player_id) myPickedIds.add(pick.player_id);
  });

  PLAYOFF_DAYS.forEach(day => {
    day.players.forEach(p => {
      p.used = myPickedIds.has(p.id) && !(myUserPicks[day.isoDate]?.player_id === p.id);
    });
  });
}

