async function initApp(user) {
  currentUser = user;
  const email = user.email.toLowerCase();
  currentProfile = USER_MAP[email] || { name: email.split('@')[0], color: '#f5c518', admin: false };

  // Set avatar
  const av = document.getElementById('userAvatar');
  av.textContent = currentProfile.name[0];
  av.style.background = `linear-gradient(135deg,${currentProfile.color},${currentProfile.color}88)`;

  // Show admin panel if admin
  if (currentProfile.admin) {
    document.getElementById('adminPanel').style.display = 'block';
    document.getElementById('adminDate').value = new Date().toISOString().split('T')[0];
  }

  // Switch screens
  document.getElementById('loginScreen').classList.remove('active');
  document.getElementById('appScreen').classList.add('active');

  // Seed day 1 picks if not already in DB
