function isDayLocked(day) {
  if (day.status === 'locked') return true;
  // For 'open' days, check if first game has started (simplified: use current time)
  // In production this would check actual tip-off times
  return false;
}

// ── CALENDAR ──
function renderCalendar() {
  const strip = document.getElementById('calendarStrip');
  strip.innerHTML = PLAYOFF_DAYS.map(day => {
    const isActive = day.id === activeDayId;
    const myPick = allPicks[currentUser.id]?.[day.isoDate];
    const hasPick = !!myPick;
    const isToday = day.id === 1;
    let cls = 'day-pill' + (isActive?' active':'') + (day.status==='locked'?' locked':'');
    return `<div class="${cls}" onclick="selectDay(${day.id})">
      ${isToday?'<div class="dp-today">TODAY</div>':''}
      <div class="dp-day">${day.dayName}</div>
      <div class="dp-date">${day.shortDate}</div>
      <div class="dp-teams">${day.games.map(g=>`${g.home}·${g.away}`).join('<br>')}</div>
      ${hasPick && day.status!=='locked' ? '<div class="pick-dot"></div>' : ''}
      ${hasPick && day.status==='locked' ? '<div class="lock-dot"></div>' : ''}
    </div>`;
  }).join('');
}

function selectDay(dayId) {
  activeDayId = dayId;
  selectedPlayerId = null;
  editingDay = false;
  document.getElementById('confirmBar').style.display = 'none';
  renderCalendar();
  renderDayView(dayId);
}

