function renderDayView(dayId) {
  const day = PLAYOFF_DAYS.find(d => d.id === dayId);
  const isLocked = isDayLocked(day);
  const isToday = day.id === 1;
  const myPick = allPicks[currentUser.id]?.[day.isoDate];
  const myPickPlayer = myPick ? day.players.find(p => p.id === myPick.player_id) : null;
  const showPlayers = !isLocked || true; // always show players

  // Status badge
  let badge = '';
  if (isLocked) badge = `<div class="status-badge locked"><div class="dot red"></div>LOCKED</div>`;
  else if (isToday) badge = `<div class="status-badge open"><div class="dot green"></div>OPEN · LOCKS AT TIP-OFF</div>`;
  else badge = `<div class="status-badge future"><div class="dot gold"></div>UPCOMING · CHANGE ANYTIME</div>`;

  // Pick section
  let pickHtml = '';
  if (isLocked && myPick) {
    const total = myPick.pts != null ? myPick.pts + myPick.reb + myPick.ast : '—';
    const statsStr = myPick.pts != null ? `${myPick.pts} pts · ${myPick.reb} reb · ${myPick.ast} ast` : 'Stats pending...';
    pickHtml = `<div class="section-label">YOUR LOCKED PICK</div>
    <div class="my-pick-card">
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="pick-slot-locked">🔒</div>
        <div class="pick-info"><h3>${myPick.player_name}</h3><p>${myPick.team} · ${statsStr}</p></div>
        <div class="pick-total">${total}</div>
      </div>
    </div>`;
  } else if (isLocked && !myPick) {
    pickHtml = `<div class="section-label">YOUR PICK</div>
    <div class="my-pick-card">
      <div class="pick-empty"><div class="pick-slot">😬</div><div><div style="font-weight:600;font-size:14px;">No pick made</div><div style="font-size:12px;margin-top:3px;color:var(--muted);">This day is now locked</div></div></div>
    </div>`;
  } else if (myPick && !editingDay) {
    const avg = (myPick.player_id && myPickPlayer) ? (myPickPlayer.pts+myPickPlayer.reb+myPickPlayer.ast).toFixed(1) : '—';
    pickHtml = `<div class="section-label">YOUR PICK — TAP EDIT TO CHANGE</div>
    <div class="my-pick-card">
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="pick-slot-saved">⭐</div>
        <div class="pick-info"><h3>${myPick.player_name}</h3><p>${myPick.team} · Avg ${avg} total</p></div>
        <div class="pick-actions">
          <div class="pick-total">${avg}</div>
          <button class="btn-edit" onclick="startEditing()">✏️ Edit</button>
        </div>
      </div>
    </div>`;
  } else {
    pickHtml = `<div class="section-label">${myPick?'SWAP YOUR PICK':'SELECT A PLAYER'}</div>
    <div class="my-pick-card">
      <div class="pick-empty">
        <div class="pick-slot">🏀</div>
        <div><div style="font-weight:600;font-size:14px;">${myPick?`Currently: ${myPick.player_name}`:'No pick yet'}</div><div style="font-size:12px;margin-top:3px;color:var(--muted);">Tap any player to select</div></div>
      </div>
    </div>`;
  }

  // Player grids
  const grids = day.games.map(g => {
    const gamePlayers = day.players.filter(p => p.team === g.home || p.team === g.away);
    const cards = gamePlayers.map(p => {
      const isSaved = myPick?.player_id === p.id;
      const isSelected = selectedPlayerId === p.id;
      let cls = 'player-card';
      if (p.used && !isSaved) cls += ' used';
      else if (isLocked) cls += ' day-locked';
      if ((isSaved && !editingDay) || isSelected) cls += ' selected';
      const clickable = !p.used && !isLocked && (editingDay || !myPick || isSaved);
      const avgTotal = (p.pts+p.reb+p.ast).toFixed(1);
      const badge = (isSaved && !editingDay) ? '<span class="card-badge badge-pick">✓ SAVED</span>'
                  : isSelected ? '<span class="card-badge badge-pick">→ SELECT</span>'
                  : (p.used && !isSaved) ? '<span class="card-badge badge-used">USED</span>' : '';
      return `<div class="${cls}" onclick="${clickable?`pickPlayer('${p.id}',${day.id})`:''}">
        ${badge}
        <div class="player-name">${p.name}</div>
        <div class="player-pos">${p.team} · ${p.pos}</div>
        <div class="player-stats">
          <div class="stat"><div class="val">${p.pts}</div><div class="lbl">PTS</div></div>
          <div class="stat"><div class="val">${p.reb}</div><div class="lbl">REB</div></div>
          <div class="stat"><div class="val">${p.ast}</div><div class="lbl">AST</div></div>
        </div>
        <div class="avg-lbl">∑ ${avgTotal} avg</div>
      </div>`;
    }).join('');
    return `<div class="game-section">
      <div class="game-header">
        <span class="team-tag" style="background:${g.homeBg};color:${g.homeColor};border:1px solid ${g.homeColor}44">${g.home}</span>
        <span class="vs">vs</span>
        <span class="team-tag" style="background:${g.awayBg};color:${g.awayColor};border:1px solid ${g.awayColor}44">${g.away}</span>
        <span class="game-meta">${g.label}</span>
        <span class="game-time">${g.time}</span>
      </div>
      <div class="player-grid">${cards}</div>
    </div>`;
  }).join('');

  document.getElementById('dayView').innerHTML = `
    <div class="day-header"><h1>${day.dayName} <span>${day.date}</span></h1>${badge}</div>
    ${pickHtml}
    ${!isLocked ? `<div class="section-label" style="margin-top:4px;">ALL PLAYERS — PICK ONE</div>` : `<div class="section-label" style="margin-top:4px;">PLAYERS FROM THIS DAY</div>`}
    ${grids}`;
}

function startEditing() {
  editingDay = true;
  selectedPlayerId = null;
  document.getElementById('confirmBar').style.display = 'none';
  renderDayView(activeDayId);
}

function pickPlayer(playerId, dayId) {
  const day = PLAYOFF_DAYS.find(d => d.id === dayId);
  if (isDayLocked(day)) return;
  selectedPlayerId = playerId;
  const player = day.players.find(p => p.id === playerId);
  document.getElementById('confirmBar').style.display = 'flex';
  document.getElementById('confirmName').textContent = player.name;
  renderDayView(dayId);
}

async function savePick() {
  if (!selectedPlayerId) return;
  const day = PLAYOFF_DAYS.find(d => d.id === activeDayId);
  const player = day.players.find(p => p.id === selectedPlayerId);
  const wasEdit = !!(allPicks[currentUser.id]?.[day.isoDate]);

  // Upsert pick
  const { error } = await sb.from('picks').upsert({
    user_id: currentUser.id,
    day_date: day.isoDate,
    player_id: player.id,
    player_name: player.name,
    team: player.team,
    locked: false,
  }, { onConflict: 'user_id,day_date' });

  if (error) { showToast('Error saving pick', false, true); return; }

  selectedPlayerId = null;
  editingDay = false;
  document.getElementById('confirmBar').style.display = 'none';

  await loadAllPicks();
  markUsedPlayers();
  renderCalendar();
  renderDayView(activeDayId);
  renderHistory();

  showToast(wasEdit ? `✏️ Changed to ${player.name}` : `✅ ${player.name} saved!`, wasEdit);
}

// ── STANDINGS ──
async function renderStandings() {
  // Get all profiles
  const { data: profiles } = await sb.from('profiles').select('*');
  const { data: picks } = await sb.from('picks').select('*');
  if (!profiles || !picks) return;

  // Calculate scores
  const scores = {};
  const pickCounts = {};
  profiles.forEach(p => { scores[p.id] = 0; pickCounts[p.id] = 0; });

  picks.forEach(pick => {
    if (pick.pts != null && pick.reb != null && pick.ast != null) {
      scores[pick.user_id] = (scores[pick.user_id] || 0) + pick.pts + pick.reb + pick.ast;
      pickCounts[pick.user_id] = (pickCounts[pick.user_id] || 0) + 1;
    }
  });

  const sorted = profiles.sort((a, b) => (scores[b.id] || 0) - (scores[a.id] || 0));
  const rankCls = ['gold','silver','bronze',''];
  const rankSym = ['🥇','🥈','🥉','4'];

  document.getElementById('lbList').innerHTML = sorted.map((p, i) => {
    const isMe = p.id === currentUser.id;
    const color = USER_MAP[Object.keys(USER_MAP).find(k => USER_MAP[k].name === p.name)]?.color || '#f5c518';
    return `<div class="lb-row${isMe?' me':''}">
      <div class="lb-rank ${rankCls[i]}">${rankSym[i]}</div>
      <div class="lb-avatar" style="background:${color}22;color:${color}">${p.name[0]}</div>
      <div class="lb-info"><h3>${p.name}${isMe?'<span class="me-tag">YOU</span>':''}</h3><p>${pickCounts[p.id]||0} pick${pickCounts[p.id]===1?'':'s'} scored</p></div>
      <div class="lb-score"><div class="big">${scores[p.id]||0}</div><div class="sm">TOTAL</div></div>
    </div>`;
  }).join('');

  // Today's picks reveal
  const today = PLAYOFF_DAYS.find(d => d.id === 1);
  const todayDate = today.isoDate;
  const todayPicks = picks.filter(p => p.day_date === todayDate);

  document.getElementById('revealsGrid').innerHTML = profiles.map(p => {
    const isMe = p.id === currentUser.id;
    const todayPick = todayPicks.find(tp => tp.user_id === p.id);
    const color = USER_MAP[Object.keys(USER_MAP).find(k => USER_MAP[k].name === p.name)]?.color || '#f5c518';

    if (!todayPick) {
      return `<div class="reveal-card hidden-card"><div class="reveal-name">${p.name}</div><div class="reveal-icon">⏳</div><div class="reveal-text">No pick yet</div></div>`;
    }
    if (!isMe && today.status !== 'locked') {
      return `<div class="reveal-card hidden-card"><div class="reveal-name">${p.name}</div><div class="reveal-icon">🔒</div><div class="reveal-text">Hidden until tip-off</div></div>`;
    }
    return `<div class="reveal-card">
      <div class="reveal-name">${p.name}${isMe?' (you)':''}</div>
      <div style="font-weight:600;font-size:13px;margin-bottom:2px;">${todayPick.player_name}</div>
      <div style="font-size:10px;color:var(--muted);">${todayPick.team}</div>
    </div>`;
  }).join('');
}

// ── HISTORY ──
async function renderHistory() {
  const { data: picks } = await sb.from('picks').select('*').eq('user_id', currentUser.id).order('day_date', { ascending: true });
  if (!picks) return;

  let total = 0;
  let scored = 0;
  picks.forEach(p => {
    if (p.pts != null) { total += p.pts + p.reb + p.ast; scored++; }
  });

  // Get rank
  const { data: allPicksData } = await sb.from('picks').select('*');
  const { data: profiles } = await sb.from('profiles').select('*');
  const userScores = {};
  if (allPicksData && profiles) {
    profiles.forEach(p => userScores[p.id] = 0);
    allPicksData.forEach(p => { if (p.pts != null) userScores[p.user_id] = (userScores[p.user_id]||0) + p.pts + p.reb + p.ast; });
  }
  const sorted = Object.entries(userScores).sort((a,b) => b[1]-a[1]);
  const rank = sorted.findIndex(([id]) => id === currentUser.id) + 1;

  document.getElementById('myTotal').textContent = total;
  document.getElementById('myName').textContent = `${currentProfile.name}'s Score`;
  document.getElementById('myRank').textContent = `#${rank}`;
  document.getElementById('myPickCount').textContent = `${picks.length} picks made · ${scored} scored`;

  document.getElementById('histList').innerHTML = picks.length === 0
    ? '<div style="padding:20px;text-align:center;color:var(--muted);font-size:13px;">No picks yet</div>'
    : picks.map(pick => {
        const day = PLAYOFF_DAYS.find(d => d.isoDate === pick.day_date);
        const dateLabel = day ? day.date : pick.day_date;
        const hasScore = pick.pts != null;
        const scoreEl = hasScore
          ? `<div class="hist-score">${pick.pts+pick.reb+pick.ast}</div>`
          : pick.locked
            ? `<div class="hist-badge locked">LOCKED</div>`
            : `<div class="hist-badge saved">SAVED</div>`;
        const statsStr = hasScore ? `${pick.pts} pts · ${pick.reb} reb · ${pick.ast} ast` : pick.team;
        return `<div class="hist-row">
          <div class="hist-date">${dateLabel}</div>
          <div class="hist-player"><h4>${pick.player_name}</h4><p>${statsStr}</p></div>
          ${scoreEl}
        </div>`;
      }).join('');
}

// ── ADMIN SCORE OVERRIDE ──
async function submitAdminScore() {
  const date = document.getElementById('adminDate').value;
  const playerName = document.getElementById('adminPlayer').value.trim();
  const score = parseInt(document.getElementById('adminScore').value);

  if (!date || !playerName || isNaN(score)) {
    showToast('Fill in all fields', false, true);
    return;
  }

  // Find pick matching this player name and date
  const { data: picks } = await sb.from('picks').select('*').eq('day_date', date).ilike('player_name', `%${playerName}%`);

  if (!picks || picks.length === 0) {
    showToast('No picks found for that player/date', false, true);
    return;
  }

  // Update all picks for this player on this date with the score
  // We'll split score 3 ways as pts for simplicity, or let admin enter breakdown
  // For now store total in pts and 0 in reb/ast as a workaround
  for (const pick of picks) {
    await sb.from('picks').update({ pts: score, reb: 0, ast: 0 }).eq('id', pick.id);
  }

  showToast(`✅ Score saved: ${playerName} — ${score}`);
  await loadAllPicks();
  renderStandings();
  renderHistory();
}

// ── TABS ──
function showTab(tab) {
  ['picks','standings','history'].forEach(t => {
    document.getElementById(`tab-${t}`).style.display = t===tab ? 'block' : 'none';
  });
  document.querySelectorAll('.nav-tab').forEach((btn, i) => {
    btn.classList.toggle('active', ['picks','standings','history'][i]===tab);
  });
  if (tab === 'standings') renderStandings();
  if (tab === 'history') renderHistory();
}

// ── TOAST ──
function showToast(msg, isEdit=false, isError=false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast' + (isEdit?' gold':'') + (isError?' red':'');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}
</script>
