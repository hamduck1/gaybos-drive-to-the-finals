<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gaybos: Drive to the Finals</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root {
    --court: #0a0a0f;
    --panel: #13131a;
    --card: #1c1c26;
    --border: #2a2a38;
    --gold: #f5c518;
    --gold-dim: #c9a014;
    --red: #e03030;
    --green: #22c55e;
    --blue: #3b82f6;
    --text: #f0f0f0;
    --muted: #6b6b80;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'DM Sans',sans-serif; background:var(--court); color:var(--text); min-height:100vh; overflow-x:hidden; }
  body::before { content:''; position:fixed; inset:0; background:radial-gradient(ellipse 80% 40% at 50% 100%,rgba(245,197,24,0.04) 0%,transparent 70%); pointer-events:none; z-index:0; }

  /* SCREENS */
  .screen { display:none; min-height:100vh; position:relative; z-index:1; }
  .screen.active { display:flex; flex-direction:column; }

  /* LOGIN */
  #loginScreen { align-items:center; justify-content:center; padding:40px 20px; }
  .login-box { width:100%; max-width:380px; text-align:center; }
  .login-logo { font-family:'Bebas Neue',sans-serif; font-size:44px; letter-spacing:3px; color:var(--gold); line-height:1.1; margin-bottom:2px; }
  .login-tag { font-family:'Bebas Neue',sans-serif; font-size:20px; letter-spacing:4px; color:var(--text); margin-bottom:6px; }
  .login-sub { color:var(--muted); font-size:11px; letter-spacing:3px; text-transform:uppercase; margin-bottom:32px; }
  .login-card { background:var(--panel); border:1px solid var(--border); border-radius:16px; padding:26px; }
  .login-card h2 { font-family:'Bebas Neue',sans-serif; font-size:19px; letter-spacing:1px; margin-bottom:18px; }
  .form-group { margin-bottom:14px; text-align:left; }
  .form-group label { font-size:11px; font-weight:600; letter-spacing:1px; text-transform:uppercase; color:var(--muted); display:block; margin-bottom:6px; }
  .form-input { width:100%; padding:12px 14px; background:var(--card); border:1px solid var(--border); border-radius:9px; color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px; outline:none; transition:border-color 0.2s; }
  .form-input:focus { border-color:var(--gold); }
  .btn-primary { width:100%; padding:13px; background:var(--gold); color:var(--court); border:none; border-radius:9px; font-family:'Bebas Neue',sans-serif; font-size:18px; letter-spacing:1px; cursor:pointer; transition:all 0.15s; margin-top:4px; }
  .btn-primary:hover { background:#ffd93d; }
  .btn-primary:disabled { opacity:0.5; cursor:not-allowed; }
  .login-error { color:var(--red); font-size:12px; margin-top:10px; display:none; }
  .login-note { margin-top:16px; font-size:11px; color:var(--muted); background:var(--card); border-radius:8px; padding:10px; border:1px solid var(--border); text-align:left; line-height:1.6; }

  /* NAV */
  nav { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid var(--border); background:rgba(10,10,15,0.97); position:sticky; top:0; z-index:100; backdrop-filter:blur(10px); gap:10px; }
  .logo { font-family:'Bebas Neue',sans-serif; font-size:17px; letter-spacing:2px; color:var(--gold); line-height:1; white-space:nowrap; }
  .logo span { color:var(--text); }
  .nav-right { display:flex; align-items:center; gap:8px; flex-shrink:0; }
  .avatar { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:14px; color:var(--court); cursor:pointer; flex-shrink:0; }
  .nav-tabs { display:flex; gap:3px; background:var(--panel); border-radius:7px; padding:3px; }
  .nav-tab { padding:5px 10px; border-radius:5px; font-size:12px; font-weight:500; cursor:pointer; color:var(--muted); transition:all 0.2s; border:none; background:none; white-space:nowrap; }
  .nav-tab:hover { color:var(--text); }
  .nav-tab.active { background:var(--card); color:var(--gold); }
  .content { flex:1; padding:18px 16px; max-width:960px; margin:0 auto; width:100%; }

  /* CALENDAR */
  .calendar-strip { display:flex; gap:7px; overflow-x:auto; padding-bottom:4px; margin-bottom:20px; scrollbar-width:none; }
  .calendar-strip::-webkit-scrollbar { display:none; }
  .day-pill { flex-shrink:0; background:var(--panel); border:1px solid var(--border); border-radius:11px; padding:9px 12px; cursor:pointer; transition:all 0.2s; text-align:center; min-width:68px; position:relative; }
  .day-pill:hover { border-color:rgba(245,197,24,0.3); }
  .day-pill.active { border-color:var(--gold); background:rgba(245,197,24,0.07); }
  .day-pill.locked { opacity:0.65; }
  .day-pill .dp-day { font-size:9px; color:var(--muted); letter-spacing:1px; text-transform:uppercase; margin-bottom:2px; }
  .day-pill .dp-date { font-family:'Bebas Neue',sans-serif; font-size:19px; color:var(--text); line-height:1; margin-bottom:3px; }
  .day-pill.active .dp-date { color:var(--gold); }
  .day-pill .dp-teams { font-size:8px; color:var(--muted); line-height:1.4; }
  .day-pill .dp-today { font-size:8px; color:var(--gold); font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:1px; }
  .pick-dot { width:6px; height:6px; border-radius:50%; background:var(--green); position:absolute; top:7px; right:7px; }
  .lock-dot { width:6px; height:6px; border-radius:50%; background:var(--red); position:absolute; top:7px; right:7px; }

  /* DAY HEADER */
  .day-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; flex-wrap:wrap; gap:8px; }
  .day-header h1 { font-family:'Bebas Neue',sans-serif; font-size:27px; letter-spacing:2px; }
  .day-header h1 span { color:var(--gold); }
  .status-badge { display:flex; align-items:center; gap:6px; padding:6px 11px; border-radius:7px; font-size:11px; font-weight:600; letter-spacing:0.5px; white-space:nowrap; }
  .status-badge.open { background:rgba(34,197,94,0.12); border:1px solid rgba(34,197,94,0.3); color:var(--green); }
  .status-badge.future { background:rgba(245,197,24,0.1); border:1px solid rgba(245,197,24,0.25); color:var(--gold); }
  .status-badge.locked { background:rgba(224,48,48,0.1); border:1px solid rgba(224,48,48,0.25); color:var(--red); }
  .dot { width:6px; height:6px; border-radius:50%; }
  .dot.green { background:var(--green); animation:pulse 2s infinite; }
  .dot.gold { background:var(--gold); }
  .dot.red { background:var(--red); }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* PICK CARD */
  .section-label { font-size:10px; font-weight:600; letter-spacing:2px; text-transform:uppercase; color:var(--muted); margin-bottom:9px; }
  .my-pick-card { background:var(--panel); border:1px solid var(--border); border-radius:13px; padding:15px; margin-bottom:20px; }
  .pick-empty { display:flex; align-items:center; gap:12px; color:var(--muted); }
  .pick-slot { width:46px; height:46px; border-radius:10px; border:2px dashed var(--border); display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
  .pick-slot-saved { width:46px; height:46px; border-radius:10px; background:linear-gradient(135deg,rgba(245,197,24,0.2),rgba(245,197,24,0.05)); border:1px solid rgba(245,197,24,0.3); display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
  .pick-slot-locked { width:46px; height:46px; border-radius:10px; background:rgba(224,48,48,0.1); border:1px solid rgba(224,48,48,0.3); display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
  .pick-info { flex:1; min-width:0; }
  .pick-info h3 { font-size:15px; font-weight:600; }
  .pick-info p { font-size:11px; color:var(--muted); margin-top:2px; }
  .pick-actions { display:flex; align-items:center; gap:7px; flex-shrink:0; }
  .pick-total { font-family:'Bebas Neue',sans-serif; font-size:26px; color:var(--gold); line-height:1; }
  .btn-edit { padding:5px 11px; background:transparent; border:1px solid var(--border); border-radius:6px; color:var(--muted); font-size:11px; font-weight:600; cursor:pointer; transition:all 0.2s; }
  .btn-edit:hover { border-color:var(--gold); color:var(--gold); }

  /* PLAYER GRID */
  .game-section { margin-bottom:22px; }
  .game-header { display:flex; align-items:center; gap:7px; margin-bottom:10px; padding-bottom:9px; border-bottom:1px solid var(--border); flex-wrap:wrap; }
  .team-tag { font-family:'Bebas Neue',sans-serif; font-size:13px; letter-spacing:1px; padding:2px 8px; border-radius:4px; }
  .vs { color:var(--muted); font-size:10px; }
  .game-meta { color:var(--muted); font-size:11px; }
  .game-time { margin-left:auto; color:var(--muted); font-size:10px; }
  .player-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:7px; }
  .player-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:11px; cursor:pointer; transition:all 0.2s; position:relative; }
  .player-card:hover:not(.used):not(.day-locked) { border-color:rgba(245,197,24,0.4); background:rgba(245,197,24,0.04); transform:translateY(-1px); }
  .player-card.selected { border-color:var(--gold); background:rgba(245,197,24,0.07); }
  .player-card.used { opacity:0.35; cursor:not-allowed; }
  .player-card.day-locked { cursor:default; }
  .player-name { font-weight:600; font-size:12px; margin-bottom:1px; line-height:1.3; }
  .player-pos { font-size:9px; color:var(--muted); margin-bottom:7px; }
  .player-stats { display:flex; gap:7px; }
  .stat { text-align:center; }
  .stat .val { font-family:'Bebas Neue',sans-serif; font-size:16px; line-height:1; }
  .stat .lbl { font-size:8px; color:var(--muted); letter-spacing:0.5px; }
  .avg-lbl { font-size:9px; color:var(--gold); margin-top:6px; font-weight:600; }
  .card-badge { position:absolute; top:7px; right:7px; font-size:8px; border-radius:3px; padding:1px 4px; font-weight:600; }
  .badge-used { color:var(--muted); background:var(--panel); border:1px solid var(--border); }
  .badge-pick { color:var(--gold); background:rgba(245,197,24,0.1); border:1px solid rgba(245,197,24,0.3); }

  /* SAVE BAR */
  .confirm-bar { position:sticky; bottom:0; background:rgba(10,10,15,0.97); border-top:1px solid var(--border); padding:12px 16px; display:flex; align-items:center; justify-content:space-between; gap:12px; backdrop-filter:blur(10px); z-index:50; }
  .confirm-info { font-size:13px; color:var(--muted); }
  .confirm-info strong { color:var(--text); }
  .btn-save { padding:10px 22px; background:var(--gold); color:var(--court); border:none; border-radius:8px; font-family:'Bebas Neue',sans-serif; font-size:16px; letter-spacing:1px; cursor:pointer; transition:all 0.15s; white-space:nowrap; }
  .btn-save:hover { background:#ffd93d; }

  /* LEADERBOARD */
  .lb-header { margin-bottom:20px; }
  .lb-header h1 { font-family:'Bebas Neue',sans-serif; font-size:28px; letter-spacing:2px; margin-bottom:3px; }
  .lb-header p { color:var(--muted); font-size:12px; }
  .lb-card { background:var(--panel); border:1px solid var(--border); border-radius:13px; overflow:hidden; margin-bottom:20px; }
  .lb-row { display:flex; align-items:center; padding:14px 16px; border-bottom:1px solid var(--border); gap:12px; }
  .lb-row:last-child { border-bottom:none; }
  .lb-row.me { background:rgba(245,197,24,0.04); }
  .lb-rank { font-family:'Bebas Neue',sans-serif; font-size:19px; width:26px; text-align:center; color:var(--muted); }
  .lb-rank.gold { color:var(--gold); }
  .lb-rank.silver { color:#b0b0c0; }
  .lb-rank.bronze { color:#cd7f32; }
  .lb-avatar { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:14px; flex-shrink:0; }
  .lb-info { flex:1; }
  .lb-info h3 { font-weight:600; font-size:14px; }
  .lb-info p { font-size:10px; color:var(--muted); margin-top:1px; }
  .lb-score { text-align:right; }
  .lb-score .big { font-family:'Bebas Neue',sans-serif; font-size:24px; line-height:1; }
  .lb-score .sm { font-size:9px; color:var(--muted); letter-spacing:0.5px; }
  .me-tag { background:rgba(245,197,24,0.1); border:1px solid rgba(245,197,24,0.2); color:var(--gold); font-size:9px; padding:1px 5px; border-radius:3px; margin-left:4px; vertical-align:middle; }

  /* PICKS REVEAL */
  .reveals-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:9px; margin-bottom:20px; }
  .reveal-card { background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:14px; }
  .reveal-card.hidden-card { background:var(--card); text-align:center; padding:22px 14px; }
  .reveal-name { font-size:10px; font-weight:500; color:var(--muted); margin-bottom:7px; text-transform:uppercase; letter-spacing:1px; }
  .reveal-icon { font-size:24px; margin-bottom:5px; }
  .reveal-text { font-size:11px; color:var(--muted); line-height:1.5; }

  /* HISTORY */
  .score-bar { background:var(--panel); border:1px solid var(--border); border-radius:13px; padding:16px; margin-bottom:20px; display:flex; align-items:center; gap:16px; }
  .score-bar .big-num { font-family:'Bebas Neue',sans-serif; font-size:48px; color:var(--gold); line-height:1; flex-shrink:0; }
  .score-bar .score-meta h3 { font-size:14px; font-weight:600; }
  .score-bar .score-meta p { font-size:11px; color:var(--muted); margin-top:3px; }
  .rank-box { margin-left:auto; text-align:center; background:rgba(245,197,24,0.08); border:1px solid rgba(245,197,24,0.2); border-radius:11px; padding:11px 15px; flex-shrink:0; }
  .rank-box .rnum { font-family:'Bebas Neue',sans-serif; font-size:34px; color:var(--gold); line-height:1; }
  .rank-box p { font-size:9px; color:var(--muted); margin-top:2px; letter-spacing:1px; text-transform:uppercase; }
  .hist-row { display:flex; align-items:center; padding:11px 0; border-bottom:1px solid var(--border); gap:11px; }
  .hist-row:last-child { border-bottom:none; }
  .hist-date { font-size:10px; color:var(--muted); width:66px; flex-shrink:0; }
  .hist-player { flex:1; }
  .hist-player h4 { font-size:12px; font-weight:600; }
  .hist-player p { font-size:10px; color:var(--muted); margin-top:2px; }
  .hist-score { font-family:'Bebas Neue',sans-serif; font-size:20px; color:var(--gold); flex-shrink:0; }
  .hist-badge { font-size:9px; font-weight:600; padding:2px 5px; border-radius:3px; flex-shrink:0; }
  .hist-badge.saved { background:rgba(245,197,24,0.1); color:var(--gold); border:1px solid rgba(245,197,24,0.2); }
  .hist-badge.locked { background:rgba(224,48,48,0.1); color:var(--red); border:1px solid rgba(224,48,48,0.2); }

  /* ADMIN */
  .admin-section { background:var(--panel); border:1px solid var(--border); border-radius:13px; padding:16px; margin-bottom:20px; }
  .admin-section h3 { font-family:'Bebas Neue',sans-serif; font-size:18px; letter-spacing:1px; margin-bottom:14px; color:var(--gold); }
  .admin-row { display:flex; align-items:center; gap:10px; margin-bottom:10px; flex-wrap:wrap; }
  .admin-row label { font-size:12px; color:var(--muted); width:120px; flex-shrink:0; }
  .admin-input { flex:1; min-width:60px; padding:7px 10px; background:var(--card); border:1px solid var(--border); border-radius:7px; color:var(--text); font-family:'DM Sans',sans-serif; font-size:13px; outline:none; }
  .btn-small { padding:7px 14px; background:var(--gold); color:var(--court); border:none; border-radius:7px; font-family:'Bebas Neue',sans-serif; font-size:14px; cursor:pointer; }

  /* LOADING */
  .loading { display:flex; align-items:center; justify-content:center; padding:40px; color:var(--muted); font-size:13px; gap:10px; }
  .spinner { width:18px; height:18px; border:2px solid var(--border); border-top-color:var(--gold); border-radius:50%; animation:spin 0.8s linear infinite; flex-shrink:0; }
  @keyframes spin { to { transform:rotate(360deg); } }

  /* TOAST */
  .toast { position:fixed; bottom:70px; left:50%; transform:translateX(-50%) translateY(20px); background:var(--green); color:white; padding:10px 20px; border-radius:50px; font-weight:600; font-size:12px; opacity:0; transition:all 0.3s; z-index:999; pointer-events:none; white-space:nowrap; }
  .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
  .toast.gold { background:var(--gold); color:var(--court); }
  .toast.red { background:var(--red); }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen" class="screen active">
  <div class="login-box">
    <div class="login-logo">GAYBOS</div>
    <div class="login-tag">DRIVE TO THE FINALS</div>
    <div class="login-sub">2026 NBA Playoffs</div>
    <div class="login-card">
      <h2>Sign In</h2>
      <div class="form-group">
        <label>Email</label>
        <input type="email" class="form-input" id="emailInput" placeholder="your@email.com" autocomplete="email">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" class="form-input" id="passwordInput" placeholder="••••••••" autocomplete="current-password">
      </div>
      <button class="btn-primary" id="loginBtn" onclick="handleLogin()" type="button">SIGN IN</button>
      <div class="login-error" id="loginError">Incorrect email or password. Try again.</div>
      <div class="login-note">First time? Check your email for an invite link to set your password before signing in.</div>
    </div>
  </div>
</div>

<!-- APP -->
<div id="appScreen" class="screen">
  <nav>
    <div class="logo">GAYBOS<span> · DRIVE TO THE FINALS</span></div>
    <div class="nav-right">
      <div class="nav-tabs">
        <button class="nav-tab active" onclick="showTab('picks')">Picks</button>
        <button class="nav-tab" onclick="showTab('standings')">Standings</button>
        <button class="nav-tab" onclick="showTab('history')">History</button>
      </div>
      <div class="avatar" id="userAvatar" onclick="handleLogout()">?</div>
    </div>
  </nav>

  <!-- PICKS TAB -->
  <div id="tab-picks" class="content">
    <div class="calendar-strip" id="calendarStrip"></div>
    <div id="dayView"><div class="loading"><div class="spinner"></div>Loading...</div></div>
  </div>

  <!-- STANDINGS TAB -->
  <div id="tab-standings" class="content" style="display:none;">
    <div class="lb-header"><h1>STANDINGS</h1><p id="standingsSubtitle">Gaybos Drive to the Finals · 2026 NBA Playoffs</p></div>
    <div class="lb-card" id="lbList"><div class="loading"><div class="spinner"></div>Loading...</div></div>
    <div class="section-label">TODAY'S PICKS — HIDDEN UNTIL TIP-OFF</div>
    <div class="reveals-grid" id="revealsGrid"></div>
  </div>

  <!-- HISTORY TAB -->
  <div id="tab-history" class="content" style="display:none;">
    <div class="score-bar">
      <div class="big-num" id="myTotal">0</div>
      <div class="score-meta">
        <h3 id="myName">—</h3>
        <p>Total PTS + REB + AST</p>
        <p style="margin-top:4px;font-size:10px;color:var(--muted);" id="myPickCount">—</p>
      </div>
      <div class="rank-box"><div class="rnum" id="myRank">—</div><p>OF 4</p></div>
    </div>
    <div class="section-label">YOUR PICKS</div>
    <div class="lb-card"><div style="padding:0 16px;" id="histList"><div class="loading"><div class="spinner"></div>Loading...</div></div></div>

    <!-- ADMIN PANEL (only shown to Hamish) -->
    <div id="adminPanel" style="display:none;margin-top:24px;">
      <div class="section-label">ADMIN — ENTER SCORES</div>
      <div class="admin-section">
        <h3>Manual Score Override</h3>
        <p style="font-size:12px;color:var(--muted);margin-bottom:14px;">Use this to enter actual game scores once games finish. Enter the player name and their PTS+REB+AST total.</p>
        <div class="admin-row">
          <label>Date</label>
          <input type="date" class="admin-input" id="adminDate">
        </div>
        <div class="admin-row">
          <label>Player Name</label>
          <input type="text" class="admin-input" id="adminPlayer" placeholder="e.g. LeBron James">
        </div>
        <div class="admin-row">
          <label>Score (P+R+A)</label>
          <input type="number" class="admin-input" id="adminScore" placeholder="e.g. 52">
        </div>
        <button class="btn-small" onclick="submitAdminScore()">SAVE SCORE</button>
      </div>
    </div>
  </div>

  <div class="confirm-bar" id="confirmBar" style="display:none;">
    <div class="confirm-info">Selecting: <strong id="confirmName">—</strong></div>
    <button class="btn-save" onclick="savePick()">SAVE PICK</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
