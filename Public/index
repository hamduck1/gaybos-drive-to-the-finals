// ── BALLDONTLIE API — fetch player game stats ──
const BDL_API = 'https://api.balldontlie.io/v1';

async function fetchPlayerStatsForDate(playerName, dateStr) {
  try {
    // Search for player
    const searchRes = await fetch(`${BDL_API}/players?search=${encodeURIComponent(playerName)}&per_page=1`);
    const searchData = await searchRes.json();
    if (!searchData.data || searchData.data.length === 0) return null;
    const playerId = searchData.data[0].id;

    // Fetch stats for that date
    const statsRes = await fetch(`${BDL_API}/stats?player_ids[]=${playerId}&dates[]=${dateStr}&per_page=1`);
    const statsData = await statsRes.json();
    if (!statsData.data || statsData.data.length === 0) return null;

    const s = statsData.data[0];
    return {
      pts: s.pts || 0,
      reb: s.reb || 0,
      ast: s.ast || 0,
      total: (s.pts || 0) + (s.reb || 0) + (s.ast || 0)
    };
  } catch (e) {
    console.log('BDL fetch error:', e);
    return null;
  }
}

